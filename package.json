{
	"name": "game-of-life",
	"version": "1.0.0",
	"description": "Conway's Game of Life - canvas-based implementation in TypeScript",
	"keywords": [
		"canvas",
		"cellular-automaton",
		"game-of-life"
	],
	"license": "MIT",
	"main": "index.js",
	"scripts": {
		"build": "tsc --noEmit && node esbuild.config.mjs",
		"fmt": "oxfmt",
		"fmt:check": "oxfmt --check",
		"lint": "oxlint --fix",
		"lint:spell": "cspell --config ./cspell.yaml \"**/*.{ts,html}\" --verbose",
		"typecheck": "tsc --noEmit",
		"dev": "pnpm build && open dist/index.html",
		"prepare": "husky"
	},
	"devDependencies": {
		"cspell": "^9.7.0",
		"esbuild": "^0.28.0",
		"husky": "^9.1.7",
		"oxfmt": "^0.42.0",
		"oxlint": "^1.59.0",
		"typescript": "^6.0.2"
	},
	"packageManager": "pnpm@10.32.1"
}